{
  "collectionName": "components_shared_seos",
  "info": {
    "displayName": "SEO",
    "description": "Reusable page and entry metadata"
  },
  "options": {},
  "attributes": {
    "metaTitle": {
      "type": "string",
      "maxLength": 70
    },
    "metaDescription": {
      "type": "text",
      "maxLength": 180
    },
    "canonicalURL": {
      "type": "string"
    },
    "ogTitle": {
      "type": "string",
      "maxLength": 70
    },
    "ogDescription": {
      "type": "text",
      "maxLength": 180
    },
    "ogImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "noIndex": {
      "type": "boolean",
      "default": false
    },
    "structuredData": {
      "type": "json"
    }
  }
}
