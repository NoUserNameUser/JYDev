{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page",
    "description": "CMS-managed marketing and editorial pages"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
