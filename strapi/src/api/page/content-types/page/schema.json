      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "seo": {
      "type": "component",
      "component": "shared.seo"
    },
    "sections": {
      "type": "dynamiczone",
      "components": ["sections.hero", "sections.text-image", "sections.cta", "sections.faq"]
    }
  }
}
